<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patholytica</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Instrument+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
–ink: #0D0D0D;
–ink-2: #1C1C1C;
–ink-3: #3A3A3A;
–ink-4: #6E6E6E;
–ghost: #A8A8A8;
–paper: #F6F3EE;
–paper-2: #EDE9E1;
–line: rgba(0,0,0,0.1);
–accent: #C8371A;
–accent-dim: rgba(200,55,26,0.12);
–accent-glow: rgba(200,55,26,0.06);
–green: #1A6B3C;
–blue: #1A3F6B;
}

html { scroll-behavior: smooth; }

body {
font-family: ‘Instrument Sans’, sans-serif;
background: var(–paper);
color: var(–ink);
overflow-x: hidden;
cursor: none;
}

/* CUSTOM CURSOR */
.cursor {
width: 8px; height: 8px;
background: var(–accent);
border-radius: 50%;
position: fixed;
top: 0; left: 0;
pointer-events: none;
z-index: 9999;
transition: transform 0.1s;
mix-blend-mode: multiply;
}
.cursor-ring {
width: 32px; height: 32px;
border: 1px solid var(–accent);
border-radius: 50%;
position: fixed;
top: 0; left: 0;
pointer-events: none;
z-index: 9998;
transition: all 0.18s cubic-bezier(.25,.46,.45,.94);
opacity: 0.5;
}

/* NAV */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 1000;
padding: 24px 48px;
display: flex;
align-items: center;
justify-content: space-between;
mix-blend-mode: multiply;
}

.nav-logo {
font-family: ‘Cormorant Garamond’, serif;
font-size: 22px;
font-weight: 600;
letter-spacing: 0.05em;
color: var(–ink);
text-transform: uppercase;
}

.nav-logo span {
color: var(–accent);
}

.nav-links {
display: flex; align-items: center; gap: 36px;
list-style: none;
}

.nav-links a {
font-size: 12px;
font-weight: 500;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–ink-3);
text-decoration: none;
transition: color 0.2s;
}

.nav-links a:hover { color: var(–accent); }

/* HERO */
.hero {
min-height: 100vh;
display: flex;
align-items: center;
justify-content: center;
position: relative;
overflow: hidden;
padding: 0 48px;
}

/* Background grid */
.hero-grid {
position: absolute;
inset: 0;
background-image:
linear-gradient(var(–line) 1px, transparent 1px),
linear-gradient(90deg, var(–line) 1px, transparent 1px);
background-size: 60px 60px;
opacity: 0.5;
}

/* Floating anatomical marks */
.hero-marks {
position: absolute;
inset: 0;
pointer-events: none;
overflow: hidden;
}

.mark {
position: absolute;
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
color: var(–ink-4);
opacity: 0;
animation: markFloat 20s infinite;
}

@keyframes markFloat {
0% { opacity: 0; transform: translateY(20px); }
10% { opacity: 0.18; }
90% { opacity: 0.18; }
100% { opacity: 0; transform: translateY(-20px); }
}

.mark:nth-child(1)  { top: 12%; left: 8%;   font-size: 11px; animation-delay: 0s;   animation-duration: 18s; }
.mark:nth-child(2)  { top: 72%; left: 6%;   font-size: 10px; animation-delay: 3s;   animation-duration: 22s; }
.mark:nth-child(3)  { top: 25%; right: 10%; font-size: 12px; animation-delay: 6s;   animation-duration: 19s; }
.mark:nth-child(4)  { top: 60%; right: 7%;  font-size: 10px; animation-delay: 1.5s; animation-duration: 21s; }
.mark:nth-child(5)  { top: 85%; left: 20%;  font-size: 11px; animation-delay: 9s;   animation-duration: 17s; }
.mark:nth-child(6)  { top: 40%; left: 3%;   font-size: 10px; animation-delay: 4.5s; animation-duration: 23s; }

/* Diagonal accent line */
.hero::before {
content: ‘’;
position: absolute;
top: -10%;
right: 20%;
width: 1px;
height: 120%;
background: linear-gradient(to bottom, transparent, var(–accent), transparent);
opacity: 0.15;
transform: rotate(8deg);
}

.hero-content {
text-align: center;
position: relative;
z-index: 2;
max-width: 900px;
}

.hero-eyebrow {
display: inline-flex;
align-items: center;
gap: 10px;
font-size: 11px;
font-weight: 500;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 28px;
opacity: 0;
animation: fadeUp 0.8s 0.2s ease forwards;
}

.eyebrow-line {
width: 32px; height: 1px;
background: var(–accent);
}

.hero-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(72px, 10vw, 130px);
font-weight: 300;
line-height: 0.92;
letter-spacing: -0.02em;
color: var(–ink);
margin-bottom: 36px;
opacity: 0;
animation: fadeUp 0.9s 0.35s ease forwards;
}

.hero-title em {
font-style: italic;
color: var(–accent);
}

.hero-title .title-line-2 {
display: block;
padding-left: 80px;
}

.hero-sub {
font-size: 15px;
line-height: 1.7;
color: var(–ink-3);
max-width: 480px;
margin: 0 auto 52px;
opacity: 0;
animation: fadeUp 0.8s 0.5s ease forwards;
}

.hero-cta {
opacity: 0;
animation: fadeUp 0.8s 0.65s ease forwards;
display: flex;
align-items: center;
justify-content: center;
gap: 20px;
}

.btn-enter {
display: inline-flex;
align-items: center;
gap: 12px;
background: var(–ink);
color: var(–paper);
font-family: ‘Instrument Sans’, sans-serif;
font-size: 13px;
font-weight: 500;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 16px 36px;
border: none;
border-radius: 2px;
cursor: none;
transition: all 0.3s cubic-bezier(.25,.46,.45,.94);
text-decoration: none;
position: relative;
overflow: hidden;
}

.btn-enter::before {
content: ‘’;
position: absolute;
inset: 0;
background: var(–accent);
transform: scaleX(0);
transform-origin: left;
transition: transform 0.4s cubic-bezier(.25,.46,.45,.94);
}

.btn-enter:hover::before { transform: scaleX(1); }
.btn-enter span { position: relative; z-index: 1; }

.btn-enter svg {
position: relative; z-index: 1;
transition: transform 0.3s;
}

.btn-enter:hover svg { transform: translateX(4px); }

.btn-ghost {
display: inline-flex;
align-items: center;
gap: 8px;
background: none;
color: var(–ink-3);
font-family: ‘Instrument Sans’, sans-serif;
font-size: 12px;
font-weight: 500;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 16px 4px;
border: none;
border-bottom: 1px solid var(–line);
cursor: none;
transition: all 0.2s;
text-decoration: none;
}

.btn-ghost:hover { color: var(–ink); border-color: var(–ink); }

/* SCROLL INDICATOR */
.scroll-hint {
position: absolute;
bottom: 40px;
left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 8px;
opacity: 0;
animation: fadeUp 1s 1.2s ease forwards;
cursor: none;
}

.scroll-hint span {
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–ghost);
}

.scroll-line {
width: 1px;
height: 48px;
background: linear-gradient(to bottom, var(–ghost), transparent);
animation: scrollPulse 2s infinite;
}

@keyframes scrollPulse {
0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
50% { opacity: 1; transform: scaleY(1); }
}

/* SECTION COMMON */
section {
padding: 120px 48px;
position: relative;
}

/* MARQUEE */
.marquee-section {
padding: 0;
border-top: 1px solid var(–line);
border-bottom: 1px solid var(–line);
background: var(–ink);
overflow: hidden;
}

.marquee-track {
display: flex;
white-space: nowrap;
animation: marquee 22s linear infinite;
}

.marquee-track-reverse {
animation-direction: reverse;
}

@keyframes marquee {
from { transform: translateX(0); }
to { transform: translateX(-50%); }
}

.marquee-item {
display: inline-flex;
align-items: center;
gap: 24px;
padding: 18px 40px;
font-family: ‘Cormorant Garamond’, serif;
font-size: 16px;
font-weight: 300;
letter-spacing: 0.05em;
color: var(–paper);
opacity: 0.6;
}

.marquee-dot {
width: 4px; height: 4px;
background: var(–accent);
border-radius: 50%;
flex-shrink: 0;
}

/* FEATURES SECTION */
.features {
background: var(–paper);
}

.section-label {
display: flex;
align-items: center;
gap: 16px;
font-size: 10px;
font-weight: 500;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–ghost);
margin-bottom: 80px;
}

.section-label::after {
content: ‘’;
flex: 1;
height: 1px;
background: var(–line);
}

.features-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1px;
background: var(–line);
border: 1px solid var(–line);
max-width: 1100px;
margin: 0 auto;
}

.feature-cell {
background: var(–paper);
padding: 56px 52px;
position: relative;
overflow: hidden;
transition: background 0.4s;
}

.feature-cell::before {
content: ‘’;
position: absolute;
inset: 0;
background: var(–ink);
transform: scaleY(0);
transform-origin: bottom;
transition: transform 0.5s cubic-bezier(.25,.46,.45,.94);
z-index: 0;
}

.feature-cell:hover::before { transform: scaleY(1); }

.feature-cell > * { position: relative; z-index: 1; transition: color 0.3s; }
.feature-cell:hover .feature-num { color: var(–accent); }
.feature-cell:hover .feature-title { color: var(–paper); }
.feature-cell:hover .feature-desc { color: rgba(246,243,238,0.55); }

.feature-num {
font-family: ‘Cormorant Garamond’, serif;
font-size: 13px;
font-weight: 300;
letter-spacing: 0.15em;
color: var(–ghost);
margin-bottom: 28px;
display: block;
transition: color 0.3s;
}

.feature-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 32px;
font-weight: 300;
line-height: 1.2;
letter-spacing: -0.01em;
color: var(–ink);
margin-bottom: 16px;
transition: color 0.3s;
}

.feature-title em { font-style: italic; }

.feature-desc {
font-size: 14px;
line-height: 1.7;
color: var(–ink-4);
max-width: 320px;
transition: color 0.3s;
}

/* STATS */
.stats-section {
background: var(–paper-2);
border-top: 1px solid var(–line);
border-bottom: 1px solid var(–line);
}

.stats-row {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1px;
background: var(–line);
max-width: 900px;
margin: 0 auto;
}

.stat-cell {
background: var(–paper-2);
padding: 56px 40px;
text-align: center;
}

.stat-num {
font-family: ‘Cormorant Garamond’, serif;
font-size: 72px;
font-weight: 300;
line-height: 1;
letter-spacing: -0.03em;
color: var(–ink);
margin-bottom: 10px;
}

.stat-num span {
color: var(–accent);
}

.stat-label {
font-size: 11px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–ghost);
}

/* PREVIEW SECTION */
.preview-section {
background: var(–paper);
overflow: hidden;
}

.preview-inner {
max-width: 1200px;
margin: 0 auto;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 80px;
align-items: center;
}

.preview-text h2 {
font-family: ‘Cormorant Garamond’, serif;
font-size: 52px;
font-weight: 300;
line-height: 1.15;
letter-spacing: -0.02em;
margin-bottom: 24px;
}

.preview-text h2 em { font-style: italic; color: var(–accent); }

.preview-text p {
font-size: 14px;
line-height: 1.8;
color: var(–ink-3);
margin-bottom: 40px;
}

.preview-modules {
list-style: none;
display: flex;
flex-direction: column;
gap: 1px;
}

.preview-module {
display: flex;
align-items: center;
gap: 16px;
padding: 16px 20px;
background: var(–paper-2);
border-left: 2px solid transparent;
font-size: 13px;
font-weight: 500;
color: var(–ink-3);
cursor: none;
transition: all 0.2s;
}

.preview-module:hover {
border-left-color: var(–accent);
background: var(–paper);
color: var(–ink);
padding-left: 28px;
}

.mod-icon {
width: 28px; height: 28px;
border-radius: 4px;
display: flex; align-items: center; justify-content: center;
font-size: 14px;
flex-shrink: 0;
}

/* MOCK DASHBOARD WINDOW */
.preview-window {
position: relative;
border-radius: 12px;
overflow: hidden;
box-shadow:
0 0 0 1px var(–line),
0 24px 80px rgba(0,0,0,0.14),
0 8px 24px rgba(0,0,0,0.08);
transform: perspective(1200px) rotateY(-8deg) rotateX(2deg);
transition: transform 0.6s cubic-bezier(.25,.46,.45,.94);
}

.preview-window:hover {
transform: perspective(1200px) rotateY(-2deg) rotateX(1deg);
}

.win-bar {
background: var(–ink-2);
padding: 12px 16px;
display: flex;
align-items: center;
gap: 7px;
}

.win-dot {
width: 10px; height: 10px;
border-radius: 50%;
}

.win-content {
background: var(–paper);
padding: 20px;
}

.mock-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 16px;
padding-bottom: 12px;
border-bottom: 1px solid var(–line);
}

.mock-logo {
font-family: ‘Cormorant Garamond’, serif;
font-size: 14px;
font-weight: 600;
letter-spacing: 0.08em;
color: var(–ink);
}

.mock-tag {
font-size: 10px;
background: var(–accent-dim);
color: var(–accent);
padding: 3px 8px;
border-radius: 3px;
letter-spacing: 0.08em;
text-transform: uppercase;
}

.mock-grid {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 8px;
margin-bottom: 12px;
}

.mock-stat {
background: var(–paper-2);
border-radius: 6px;
padding: 10px 12px;
}

.mock-stat-val {
font-family: ‘Cormorant Garamond’, serif;
font-size: 22px;
font-weight: 300;
color: var(–ink);
line-height: 1;
margin-bottom: 2px;
}

.mock-stat-lbl {
font-size: 9px;
color: var(–ghost);
letter-spacing: 0.08em;
text-transform: uppercase;
}

.mock-bar-row {
display: flex;
flex-direction: column;
gap: 6px;
}

.mock-bar {
display: flex;
align-items: center;
gap: 8px;
font-size: 10px;
color: var(–ink-4);
}

.mock-bar-track {
flex: 1;
height: 4px;
background: var(–paper-2);
border-radius: 2px;
overflow: hidden;
}

.mock-bar-fill {
height: 100%;
border-radius: 2px;
background: var(–accent);
}

/* TESTIMONIALS / QUOTES */
.quotes-section {
background: var(–ink);
color: var(–paper);
padding: 100px 48px;
}

.quotes-label {
font-size: 10px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–ghost);
margin-bottom: 64px;
display: flex;
align-items: center;
gap: 16px;
}

.quotes-label::after {
content: ‘’;
flex: 1;
height: 1px;
background: rgba(255,255,255,0.08);
}

.quotes-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1px;
background: rgba(255,255,255,0.06);
max-width: 1100px;
margin: 0 auto;
}

.quote-cell {
background: var(–ink);
padding: 40px 36px;
transition: background 0.3s;
}

.quote-cell:hover { background: var(–ink-2); }

.quote-text {
font-family: ‘Cormorant Garamond’, serif;
font-size: 20px;
font-weight: 300;
font-style: italic;
line-height: 1.6;
color: rgba(246,243,238,0.85);
margin-bottom: 24px;
}

.quote-author {
font-size: 11px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–ghost);
}

.quote-role {
font-size: 11px;
color: var(–accent);
margin-top: 3px;
}

/* FINAL CTA */
.cta-section {
background: var(–paper);
text-align: center;
padding: 160px 48px;
position: relative;
overflow: hidden;
}

.cta-bg {
position: absolute;
top: 50%; left: 50%;
transform: translate(-50%, -50%);
width: 600px; height: 600px;
background: radial-gradient(circle, var(–accent-glow) 0%, transparent 70%);
pointer-events: none;
}

.cta-section h2 {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(52px, 7vw, 96px);
font-weight: 300;
line-height: 1.05;
letter-spacing: -0.02em;
margin-bottom: 28px;
position: relative;
}

.cta-section h2 em { font-style: italic; color: var(–accent); }

.cta-section p {
font-size: 15px;
color: var(–ink-3);
max-width: 420px;
margin: 0 auto 52px;
line-height: 1.7;
position: relative;
}

.cta-btn-wrap { position: relative; }

.btn-large {
display: inline-flex;
align-items: center;
gap: 16px;
background: var(–accent);
color: white;
font-family: ‘Instrument Sans’, sans-serif;
font-size: 14px;
font-weight: 500;
letter-spacing: 0.12em;
text-transform: uppercase;
padding: 20px 52px;
border: none;
border-radius: 2px;
cursor: none;
transition: all 0.3s;
text-decoration: none;
position: relative;
overflow: hidden;
}

.btn-large::after {
content: ‘’;
position: absolute;
inset: 0;
background: rgba(0,0,0,0.2);
transform: scaleX(0);
transform-origin: right;
transition: transform 0.3s;
}

.btn-large:hover::after { transform: scaleX(1); }

.btn-large span { position: relative; z-index: 1; }
.btn-large svg { position: relative; z-index: 1; transition: transform 0.3s; }
.btn-large:hover svg { transform: translateX(5px); }

/* FOOTER */
footer {
background: var(–ink);
color: rgba(246,243,238,0.4);
padding: 40px 48px;
display: flex;
align-items: center;
justify-content: space-between;
border-top: 1px solid rgba(255,255,255,0.06);
}

.footer-logo {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-weight: 300;
letter-spacing: 0.1em;
color: rgba(246,243,238,0.6);
text-transform: uppercase;
}

.footer-copy { font-size: 12px; letter-spacing: 0.05em; }

/* SCROLL REVEAL */
.reveal {
opacity: 0;
transform: translateY(30px);
transition: opacity 0.8s cubic-bezier(.25,.46,.45,.94), transform 0.8s cubic-bezier(.25,.46,.45,.94);
}

.reveal.visible {
opacity: 1;
transform: translateY(0);
}

.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

/* PARALLAX STRIPE */
.stripe {
position: absolute;
width: 1px;
background: linear-gradient(to bottom, transparent, var(–accent), transparent);
opacity: 0.08;
pointer-events: none;
}

/* ANIMATIONS */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(18px); }
to { opacity: 1; transform: translateY(0); }
}

/* SELECTION */
::selection { background: var(–accent); color: white; }
</style>

</head>
<body>

<!-- CURSOR -->

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->

<nav>
  <div class="nav-logo">Path<span>o</span>lytica</div>
  <ul class="nav-links">
    <li><a href="#">Features</a></li>
    <li><a href="#">Library</a></li>
    <li><a href="#">Groups</a></li>
    <li><a href="#">About</a></li>
  </ul>
</nav>

<!-- HERO -->

<section class="hero" id="hero">
  <div class="hero-grid"></div>
  <div class="hero-marks">
    <span class="mark">Hepatocellular carcinoma</span>
    <span class="mark">Glomerulonephritis</span>
    <span class="mark">Crohn's disease — ileal</span>
    <span class="mark">Squamous cell metaplasia</span>
    <span class="mark">Coagulative necrosis</span>
    <span class="mark">Hyperplastic polyp</span>
  </div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="eyebrow-line"></span>
      Medical Education Platform
      <span class="eyebrow-line"></span>
    </div>
    <h1 class="hero-title">
      Patho<em>lytica</em>
      <span class="title-line-2">Learn deeper.</span>
    </h1>
    <p class="hero-sub">
      A precision-built platform for medical students — structured courses, collaborative libraries, and intelligent planning tools.
    </p>
    <div class="hero-cta">
      <a href="#dashboard" class="btn-enter">
        <span>Enter Platform</span>
        <svg width="16" height="16" fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </a>
      <a href="#features" class="btn-ghost">
        Explore features
      </a>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- MARQUEE -->

<div class="marquee-section">
  <div class="marquee-track">
    <span class="marquee-item"><span class="marquee-dot"></span> GIT & Hepatology</span>
